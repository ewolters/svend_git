[run]
source = .
omit =
    */migrations/*
    */tests/*
    */test_*
    */__pycache__/*
    manage.py
    gunicorn.conf.py
    staticfiles/*
    media/*
    logs/*
    */apps.py
    */admin.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
    pass
    except ImportError
    if TYPE_CHECKING
show_missing = True
precision = 1
# ⚠ COMPLIANCE-CRITICAL: This threshold is enforced by the test_coverage
# compliance check (syn/audit/compliance.py). The ratchet in compliance.py
# (_COVERAGE_RATCHET) is the authoritative gate — this setting is a
# secondary enforcement for direct pytest --cov runs.
# DO NOT lower without a ChangeRequest (CHG-001).
fail_under = 45

[html]
directory = htmlcov

[json]
output = coverage.json
