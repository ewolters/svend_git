let capacityOrders = [
    { id: 1, name: 'WO-001', hours: 6, startDay: 1 },
    { id: 2, name: 'WO-002', hours: 8, startDay: 1 },
    { id: 3, name: 'WO-003', hours: 4, startDay: 2 },
