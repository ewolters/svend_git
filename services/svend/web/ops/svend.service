[Unit]
Description=Svend AI Agents
After=network.target

[Service]
Type=exec
User=eric
Group=eric
WorkingDirectory=%h/kjerne/services/svend/web
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin"
ExecStart=%h/kjerne/services/svend/web/ops/start_prod.sh
ExecReload=/bin/kill -s HUP $MAINPID
Restart=always
RestartSec=5

# Resource limits
MemoryMax=4G
CPUQuota=200%

[Install]
WantedBy=multi-user.target
