[Unit]
Description=Purge old Svend data (30 days)
After=network.target postgresql.service

[Service]
Type=oneshot
User=eric
Group=eric
WorkingDirectory=%h/kjerne/services/svend/web
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin"
ExecStart=%h/kjerne/services/svend/web/ops/run_purge.sh

[Install]
WantedBy=multi-user.target
